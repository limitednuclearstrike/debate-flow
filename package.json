{
	"name": "debate-flow",
	"version": "0.0.1",
	"private": true,
	"scripts": {
		"dev": "vite dev",
		"build": "vite build",
		"preview": "vite preview",
		"test": "playwright test",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"lint": "prettier --plugin-search-dir . --check . && eslint .",
		"format": "prettier --plugin-search-dir . --write .",
		"build:electron:web": "cross-env BUILD_TARGET=electron vite build",
		"electron:start": "npm run build:electron:web && electron .",
		"electron:dist:win": "npm run build:electron:web && electron-builder --win nsis"
	},
	"devDependencies": {
		"@playwright/test": "^1.44.1",
		"@sveltejs/adapter-vercel": "^4.0.0",
		"@sveltejs/kit": "^2.5.17",
		"@sveltejs/vite-plugin-svelte": "^3.0.0",
		"@typescript-eslint/eslint-plugin": "^5.45.0",
		"@typescript-eslint/parser": "^5.45.0",
		"eslint": "^8.28.0",
		"eslint-config-prettier": "^8.5.0",
		"eslint-plugin-svelte": "^2.30.0",
		"prettier": "^2.8.0",
		"prettier-plugin-svelte": "^2.10.1",
		"svelte": "^4.0.0",
		"svelte-check": "^3.4.3",
		"tslib": "^2.4.1",
		"typescript": "^5.0.0",
		"vite": "^5.0.0",
		"@sveltejs/adapter-static": "^3.0.0",
		"cross-env": "^7.0.3",
		"electron": "^31.0.2",
		"electron-builder": "^24.13.3"
	},
	"type": "module",
	"dependencies": {
		"@fontsource/merriweather-sans": "^5.0.4",
		"@types/animejs": "^3.1.7",
		"@urql/svelte": "^4.0.3",
		"@vercel/analytics": "^1.0.1",
		"animejs": "^3.2.1",
		"exceljs": "^4.3.0",
		"graphql": "^16.7.1",
		"ts-results": "^3.3.0"
	},
	"main": "electron/main.cjs",
	"build": {
		"appId": "com.flower.app",
		"productName": "Flower",
		"directories": {
			"output": "dist-electron"
		},
		"files": [
			"build/**/*",
			"electron/**/*",
			"package.json"
		],
		"win": {
			"target": [
				"nsis"
			]
		}
	}
}
